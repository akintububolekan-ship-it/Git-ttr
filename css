            .section-main {
                padding-top: 16px;
            }
    
            .text-area {
                padding-left: 32px;
                padding-right: 32px;
    
            }
    
            .Nav-bar {
                gap: 0px;
                margin-bottom: 32px;
            }
    
            .header-text {
                order: -1;
            }
    
            .header-text a {
                font-size: 12px;
            }
    
            .solutions {
