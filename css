                margin-top: 0;
                width: auto;
            }
    
            .mini-section2 {
                font-size: 18px;
                width: auto;
            }
    
    
            .Top-page {
                width: 100%;
                display: flex;
                flex-direction: column;
                align-items: left;
                
            }
    .Top-page button {
        margin-right: auto;
    }
            .Top-page h3 {
                text-align: left;
            }
    
            .Top-page h4 {
                text-align: left;
            }
    
            .cards-list {
                width: 338px;
            }
    
            .cards-large {
                font-size: 18px;
            }
    
            .card-small {
                font-size: 12px;
            }
    
            .cards {
                display: flex;
                flex-direction: column;
                align-items: left;
                justify-content: left;
                margin-right: auto;
            }
    
            .section-final {
                margin-left: 20px;
                margin-right: 20px;
                display: flex;
                flex-direction: column;
                gap: 32px;
            }
    
            .min {
                font-size: 22px;
            }
    
            .footer {
                font-size: 16px;
            }
        }